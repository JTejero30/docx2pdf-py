{
  "info": {
    "name": "docx2pdf-py API",
    "description": "Conversión .docx -> PDF en red local. Cambia {{base_url}} si la IP del servidor varía. El parámetro ?engine= elige el motor: auto (LibreOffice -> Word -> Python), libreoffice (páginas exactas como Word), weasyprint (Python puro, aprox.), word (solo si hay MS Office). La respuesta incluye las cabeceras X-Engine y X-Page-Count.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    { "key": "base_url", "value": "http://192.168.0.23:8000", "type": "string" }
  ],
  "item": [
    {
      "name": "Health",
      "request": {
        "method": "GET",
        "header": [],
        "url": { "raw": "{{base_url}}/health", "host": ["{{base_url}}"], "path": ["health"] },
        "description": "Comprueba que el servidor está vivo e indica el motor que usaría 'auto' y si el guardado está activo."
      }
    },
    {
      "name": "Convert - auto (recomendado)",
      "request": {
        "method": "POST",
        "header": [],
        "body": {
          "mode": "formdata",
          "formdata": [
            { "key": "file", "type": "file", "src": [], "description": "Selecciona el .docx a convertir" }
          ]
        },
        "url": {
          "raw": "{{base_url}}/convert?engine=auto",
          "host": ["{{base_url}}"],
          "path": ["convert"],
          "query": [ { "key": "engine", "value": "auto", "description": "LibreOffice -> Word -> Python según disponibilidad" } ]
        },
        "description": "Sube el .docx (Body > form-data > key 'file' tipo File) y usa 'Send and Download' para guardar el PDF. En esta máquina 'auto' usa LibreOffice (páginas exactas)."
      }
    },
    {
      "name": "Convert - libreoffice (páginas exactas)",
      "request": {
        "method": "POST",
        "header": [],
        "body": {
          "mode": "formdata",
          "formdata": [
            { "key": "file", "type": "file", "src": [], "description": "Selecciona el .docx a convertir" }
          ]
        },
        "url": {
          "raw": "{{base_url}}/convert?engine=libreoffice",
          "host": ["{{base_url}}"],
          "path": ["convert"],
          "query": [ { "key": "engine", "value": "libreoffice", "description": "Mismo nº de páginas y contenido por página que Word" } ]
        },
        "description": "Motor LibreOffice: paginación fiel a Word (para referenciar páginas). Devuelve X-Page-Count."
      }
    },
    {
      "name": "Convert - weasyprint (Python puro)",
      "request": {
        "method": "POST",
        "header": [],
        "body": {
          "mode": "formdata",
          "formdata": [
            { "key": "file", "type": "file", "src": [], "description": "Selecciona el .docx a convertir" }
          ]
        },
        "url": {
          "raw": "{{base_url}}/convert?engine=weasyprint",
          "host": ["{{base_url}}"],
          "path": ["convert"],
          "query": [ { "key": "engine", "value": "weasyprint", "description": "Sin dependencias externas; paginación aproximada" } ]
        },
        "description": "Motor Python puro (sin LibreOffice). Fidelidad visual alta pero la paginación no es exacta."
      }
    }
  ]
}
